#include <bits/stdc++.h>
using namespace std;

int subarraySum(vector<int>& nums, int K) {
    unordered_map<int,int> freq; 
    freq[0] = 1; // base case: sum=0 seen once

    int current_sum = 0;
    int count = 0;

    for (int num : nums) {
        current_sum += num;

        int need = current_sum - K;
        if (freq.find(need) != freq.end()) {
            count += freq[need]; 
        }

        freq[current_sum]++; 
    }

    return count;
}

int main() {
    vector<int> nums = {1, 2, 3};
    int K = 3;
    cout << subarraySum(nums, K) << endl; 
}
