here .... we are given an interval to be inserted in the given sequence.

  logic and template :
  first check where can the given can be insert and then insert it. 
  insert == false means it is not inserted yet before and newinterval [0] < interval[i][0]
  then push_back that newinterval and mark boolean insert as true . 


  edge case if the interval can't be inserted in between i.e it is the largest among all the starts so insert that in last . 

  after inserting the element do sort the resultant array accordingly to start. 

  vector<vector<int>> insert(vector<vector<int>>& intervals, vector<int>& newInterval) {
        int n = intervals.size();
        vector<vector<int>> res ;
        
        bool insert = false ;

    // inserting new interval in the original interval
        for(int i = 0 ; i<n ; i++){
            if(insert == false && newInterval[0]<intervals[i][0]){
                res.push_back(newInterval);
                insert = true ;
            }
            res.push_back(intervals[i]);
        }
          // edge case : insert the newinterval at the end of the given array as it is largest among all the starts.
        if(insert == false){
            res.push_back(newInterval);
        }

          // step 3 : sort all the starts of the res (result)

        sort(res.begin(), res.end());

    // create new merge (result to return) which will work on res .
        vector<vector<int>> merge;
        int start1 = res[0][0];
        int end1 = res[0][1];
        for(int i = 1 ; i< res.size(); i++){
            int start2 = res[i][0];
            int end2 = res[i][1];

            if(end1>=start2){
                start1 = start1;
                end1 = max(end1,end2);
                continue;
            }
            else{
                merge.push_back({start1,end1});
                start1 = start2;
                end1 = end2;
            }
            
        }
        merge.push_back({start1,end1});
        return merge;

    }
