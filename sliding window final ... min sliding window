 int minSubArrayLen(int k, vector<int>& nums) {
        int n = nums.size();
        int sum = 0 ;
        int low = 0 ;
        int ans = INT_MAX;
        for(int high = 0 ; high<n ; high++){
            sum += nums[high];
            while(sum >= k){
                int len = high - low + 1 ;
                ans = min(ans,len);
                sum -= nums[low];
                low ++ ;

            }
        }
        return (ans == INT_MAX)? 0 : ans;
        
    }



