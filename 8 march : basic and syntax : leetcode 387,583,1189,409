  #q4: lc 409 : longest palindrome

  even frq no issue just put them together
  odd frequency make pair and then add +1 in the result

  int longestPalindrome(string s) {
        int n = s.size();
        unordered_map<char,int> f;
        for(int i = 0 ; i<n ; i++){
            f[s[i]]++;

        }
        bool odd = false;
        int res = 0 ;
        // handle even first as even frequency will not have any issue

        for(auto it : f){
            int val = it.second;
            if(val%2 == 0){
                res+=val;
            }
            else{
                odd = true;
            }
        }
        //edge case absence of odd
        if(odd == false){
            return res ;
        }

        //handle odd ... make even no of pair and add to res then add +1

        for(auto it : f){
            int val = it.second;
            if(val%2 == 1){
                res+=val-1;
            }
        }
        return res+1;
        
    }

  
