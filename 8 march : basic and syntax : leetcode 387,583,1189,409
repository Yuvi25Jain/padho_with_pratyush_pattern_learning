#q1: lc : 387 : first unique character in string. op  return index of that element whihc is unique
 int firstUniqChar(string s) {

        int n = s.size();

        unordered_map<char,int> f;
        for(int i = 0 ; i<n ; i++){
            f[s[i]]++;
        }
        for(int i = 0 ; i<n ; i++){
            if(f[s[i]] == 1){
                return i ;
            }
        }
        return -1;
    }


