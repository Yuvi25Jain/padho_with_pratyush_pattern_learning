  #q3 : lc 1189 : maximum ballons. same as q2 but here we need to return how many pairs of ballons we can form from available.

  int maxNumberOfBalloons(string text) {
        int n = text.size();
        unordered_map<char,int> have;
        for(int i = 0 ; i<n ; i++){
            have[text[i]]++;
        }
        unordered_map<char,int> need;
        need['b'] = 1 ;
        need['a'] = 1 ;
        need['l'] = 2 ;
        need['o'] = 2 ;
        need['n'] = 1 ;

        int res = INT_MAX;
        for(auto it: need){
            char c = it.first;
            int fneed = it.second;
            int fhave = have[c];
            int times = fhave/fneed;
            res = min(res,times);
        }
        return res;
        
    }

