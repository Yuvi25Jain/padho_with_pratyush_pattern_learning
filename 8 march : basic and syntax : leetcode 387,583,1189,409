  #q2 : lc 583 : ransom (need) note (magazine available) op true or false

  bool canConstruct(string ransomNote, string magazine) {
        int n = ransomNote.size();
        int m = magazine.size();

        unordered_map<char,int>demand;
        unordered_map<char,int>available;

        for(int i = 0 ; i<n ; i++){
            demand[ransomNote[i]]++ ;
        }
        
        for(int i = 0 ; i<m ; i++){
            available[magazine[i]]++ ;
        }

        return yes(demand,available);
        
    }

    bool yes(unordered_map<char,int>& demand , unordered_map<char,int>& available ){
        for(auto it: demand){
            char c = it.first;
            int fneed = it.second;
            int favail = available[c];
            if(favail < fneed){
                return false;
            }
        }
        return true ;
    }

