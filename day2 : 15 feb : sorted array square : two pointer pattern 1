  optimised : two pointer approach. similar of merge two sorted array . 
  





vector<int> sortedSquares(vector<int>& nums) {
        int sz = nums.size();
        vector<int> a ; // negative array
        vector<int> b ; // pos array

        // check if element is pos or negative and push_back them at their respective array.

        for(int i = 0 ; i< sz ; i++){
            if(nums[i]>0){          //element is positive so push it in b
                b.push_back(nums[i]);
            }
            else{
                a.push_back(nums[i]); //element negative so push it in a 
            }
        }
        //case 1 : if all elements are negative : so they are in descedning order and sorted just reverse them 

        if(b.size() == 0){
            for(int i = 0 ; i<a.size() ; i++){
                a[i] = a[i]*a[i];
                
            }
            reverse(a.begin(), a.end());
            return a ;
            
        }

        if(a.size() == 0){ //all elements are positive no negative element . no need to do anything just return square as it is. 
            for(int i = 0 ; i<b.size() ; i++){
                b[i] = b[i]*b[i];
                
                
            }

            return b;
        }

        // case 3: it contains pos + negative elements

        int i = 0 , j = 0 ;
        int idx = 0 ;
        int n = a.size();
        int m = b.size();
        int u = n+m ;
        vector<int>result(u) ;

        for(int i = 0 ; i< n ; i++){
            a[i] = a[i]*a[i];
            
        }
        reverse(a.begin(), a.end());

        for(int i = 0 ; i<m ; i++){
            b[i] = b[i]*b[i] ;
        }
        while(i<n && j<m){
            if(a[i] <= b[j]){
                result[idx] = a[i] ;
                idx++;
                i++;
            }
            else{
                result[idx] = b[j];
                idx++;
                j++;
            }
           

        }
        while(i<n){
            result[idx] = a[i];
            idx++ ;
            i++;
        }
        while(j<m){
            result[idx] = b[j];
            idx++ ;
            j++;
        }
        return result;
        
    }
