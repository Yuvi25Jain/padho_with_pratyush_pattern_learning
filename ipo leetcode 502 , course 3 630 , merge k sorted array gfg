course 3 : leetcode 605

int scheduleCourse(vector<vector<int>>& courses) {
    // Sort courses by deadline
    sort(courses.begin(), courses.end(), [](auto &a, auto &b){
        return a[1] < b[1];
    });

    priority_queue<int> pq; // max heap for durations
    int time = 0;

    for(auto &c : courses) {
        int duration = c[0];
        int deadline = c[1];

        time += duration;
        pq.push(duration);

        // If total time exceeds deadline, drop the longest course
        if(time > deadline) {
            time -= pq.top();
            pq.pop();
        }
    }

    return pq.size();
}
