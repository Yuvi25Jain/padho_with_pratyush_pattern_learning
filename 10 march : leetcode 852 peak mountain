 int peakIndexInMountainArray(vector<int>& arr) {
        int n = arr.size();
        int low = 0 , high = n-1;
        int res = -1;

        while(low<=high){
            int mid = low + (high - low)/2 ;
            if(arr[mid] < arr[mid+1]){ //increasing
                low = mid+1;
            }
            else{ //decreasing
                res = mid ;
                high = mid-1;
            }
        }
        return res;
        
    }
